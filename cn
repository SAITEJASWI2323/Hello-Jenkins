DICTIONARY (SERVER)
import socket
HOST = "0.0.0.0"
PORT = 5000
dictionary = {
    "python": "A programming language",
    "network": "Connected computers",
    "router": "Device that forwards data",
}
def run_server():
    server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server.bind((HOST, PORT))
    server.listen(1)
    print(f"TCP Dictionary Server running on port {PORT}...")
    conn, addr = server.accept()
    print("Client connected:", addr)
    while True:
        word = conn.recv(1024).decode().lower()
        if not word or word == "exit":
            print("Client disconnected.")
            break
        if word in dictionary:
            conn.send(dictionary[word].encode())
            print("Word received from client:", word)
        else:
            conn.send("Word not found".encode())
            print("Unknown word received from client:", word)
    conn.close()
    server.close()
if __name__ == "__main__":
    run_server()

DICTIONARY (CLIENT)
import socket
SERVER = "localhost"
PORT = 5000
def run_client():
    client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    client.connect((SERVER, PORT))
    print("Connected to TCP Dictionary Server.")
    while True:
        word = input("Enter a word (or text exit): ")
        client.send(word.encode())
        if word.lower() == "exit":
            print("Closing connection....")
            break
        response = client.recv(1024).decode()
        if response == "Word not found":
            print(response)
        else:
            print("Meaning:", response)
    client.close()
if __name__ == "__main__":
    run_client()












GUESS NUMBER SERVER
import socket
import random
HOST="0.0.0.0"
PORT=5000
sock=socket.socket(socket.AF_INET,socket.SOCK_DGRAM)
sock.bind((HOST,PORT))
print("UDP Guess-It Server Started....")
magic=random.randint(1,99)
attempts=0
MAX_ATTEMPTS=10
while attempts<MAX_ATTEMPTS:
    data,addr=sock.recvfrom(1024)
    guess=int(data.decode())
    attempts+=1
    print(f"Client guessed:{guess}")
    if guess==magic:
        sock.sendto("Great".encode(),addr)
        print("Client guessed correctly.Game Over.")
        break
    elif attempts==MAX_ATTEMPTS:
        sock.sendto("Better luck next time:)".encode(),addr)
        print("Client failed in 10 attempts.")
        break
    elif guess<magic:
        sock.sendto("Higher".encode(),addr)
    elif guess>magic:
        sock.sendto("Lower".encode(),addr)
sock.close()

GUESS NUMBER CLIENT
import socket
SERVER_IP="127.0.0.1"
PORT=5000
sock=socket.socket(socket.AF_INET,socket.SOCK_DGRAM)
print("Guess the Magic Number(1–99)")
for i in range(10):
    guess=input(f"Attempt {i+1}: Enter your guess:")
    sock.sendto(guess.encode(),(SERVER_IP,PORT))
    data,_=sock.recvfrom(1024)
    response=data.decode()
    print("Server:",response)
    if response=="Great":
        break
    if response=="Better luck next time:)":
        break
sock.close()



















IMAGE_SERVER
import socket
HOST = "0.0.0.0"
PORT = 5001
BUFFER_SIZE = 4096
END_MARKER = b"__END__"
sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
sock.bind((HOST, PORT))
print("UDP Image Server started... Waiting for image...")
image_data = b""
while True:
    data, addr = sock.recvfrom(BUFFER_SIZE)
    if data == END_MARKER:
        print("Image transfer complete.")
        break
    image_data += data
with open("received_image.jpg", "wb") as f:
    f.write(image_data)
print("Image saved as received_image.jpg")
sock.close()


IMAGE_CLIENT
import socket
SERVER_IP = "127.0.0.1"   # Change if server is remote
PORT = 5001
BUFFER_SIZE = 4096
END_MARKER = b"__END__"
sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
image_path = "screen.jpg"   # Image to send
with open(image_path, "rb") as f:
    while True:
        chunk = f.read(BUFFER_SIZE)
        if not chunk:
            break
        sock.sendto(chunk, (SERVER_IP, PORT))
sock.sendto(END_MARKER, (SERVER_IP, PORT))
print("Image sent successfully.")
sock.close()


