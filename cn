import socket
from datetime import date
from calendar import monthrange
HOST = "127.0.0.1"
PORT = 9999
server = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
server.bind((HOST, PORT))
print("UDP Server is running...")
while True:
    data, addr = server.recvfrom(1024)
    try:
        dob_str = data.decode().strip()
        year, month, day = map(int, dob_str.split("-"))
        birth_date = date(year, month, day)
        today = date.today()
        years = today.year - birth_date.year
        months = today.month - birth_date.month
        days = today.day - birth_date.day
        if days < 0:
            months -= 1
            prev_month = today.month - 1 or 12
            prev_year = today.year if today.month != 1 else today.year - 1
            days += monthrange(prev_year, prev_month)[1]
        if months < 0:
            years -= 1
            months += 12
        result = f"Today's date: {today.strftime('%d/%m/%Y')}\n"
        result += f"Age: {years} years {months} months {days} days"
    except Exception:
        result = "Invalid date format! Please send date as YYYY-MM-DD"
    server.sendto(result.encode(), addr)

